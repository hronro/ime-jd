<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleDisplayName</key>
    <string>键道</string>
    <key>CFBundleExecutable</key>
    <string>JdIME</string>
    <key>CFBundleIconFile</key>
    <string>jd</string>
    <key>CFBundleIdentifier</key>
    <string>com.hronro.ime-jd</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>键道</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleSignature</key>
    <string>????</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSBackgroundOnly</key>
    <false/>
    <key>LSMinimumSystemVersion</key>
    <string>12.0</string>
    <key>LSUIElement</key>
    <true/>
    <key>NSHumanReadableCopyright</key>
    <string>Copyright © 2026 hronro. All rights reserved.</string>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>
    <key>NSSupportsSuddenTermination</key>
    <true/>

    <!-- Single-source IME registration (the style used by working third-party
         IMEs on macOS 26). NOTE: do NOT use ComponentInputModeDict / a mode
         dictionary here — the simple top-level form below is what TIS actually
         enumerates on Tahoe. -->
    <key>InputMethodType</key>
    <string>keyboard</string>
    <!-- MUST be "<bundle-id>_Connection". On macOS 12, IMKServer registers
         its mach service as "<bundle-id>_Connection" no matter what name the
         IMKServer initializer is given, while client apps look up the name
         stored here (via the TIS registration record) — any other value
         leaves clients connecting to a service that doesn't exist, so the
         IME silently never receives input (keystrokes pass through, and
         selecting 键道 in the menu bounces back). macOS 26 honors this value
         on both sides, so the bundle-id form works everywhere. -->
    <key>InputMethodConnectionName</key>
    <string>com.hronro.ime-jd_Connection</string>
    <key>InputMethodServerControllerClass</key>
    <string>JdIME_InputController</string>
    <key>InputMethodServerDelegateClass</key>
    <string>JdIME_InputController</string>
    <key>TISInputSourceID</key>
    <string>com.hronro.ime-jd</string>
    <key>TISIntendedLanguage</key>
    <string>zh-Hans</string>
    <!-- Menu-bar / input-menu icon. Without these TIS falls back to the app
         icns (which is colored); this pair is how Apple's own single-source
         IMEs (AinuIM, PluginIM) ship theirs: a dedicated black+alpha knockout
         tile that the system recolors per menu-bar appearance. jd-menu.tiff
         (16 + 32@2x) is generated by assets/icon/generate.sh. -->
    <key>tsInputMethodIconFileKey</key>
    <string>jd-menu.tiff</string>
    <key>TISIconIsTemplate</key>
    <true/>
    <key>tsInputMethodCharacterRepertoireKey</key>
    <array>
        <string>Hans</string>
    </array>
</dict>
</plist>
