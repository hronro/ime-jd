<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.JdIME">

        <activity
            android:name=".app.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Embedded keyboard preview (same KeyboardView + engine, no enabling
             needed). Not exported; MainActivity forwards the jd.* QA extras. -->
        <activity
            android:name=".app.KeyboardPreviewActivity"
            android:label="@string/preview_title"
            android:exported="false" />

        <!-- The IME itself: a Service the system binds to. This is the mandatory
             JVM entry point — Android has no native IME entry point. -->
        <service
            android:name=".ime.JdInputMethodService"
            android:label="@string/ime_name"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:exported="true">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>
    </application>
</manifest>
